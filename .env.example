# Пример переменных окружения для локальной разработки.
# Не храни секреты в репозитории. Скопируй в .env в корне (для shell) или задавай перед командой.

# --- Прокси Vite (apps/sso, apps/user, apps/admin) ---
# Читается в vite.config.ts при запуске pnpm dev:* из корня задай в окружении:
#   PowerShell: $env:BFF_ORIGIN="http://127.0.0.1:8000"
#   bash:       export BFF_ORIGIN=http://127.0.0.1:8000
# Либо создай apps/<приложение>/.env.local — Vite подхватывает .env* из каталога этого приложения (не из корня монорепо).
BFF_ORIGIN=http://127.0.0.1:8000

# --- Опционально: публичные переменные Vite (префикс VITE_) ---
# Задаются в apps/<приложение>/.env.local — см. документацию Vite.
# VITE_APP_NAME=Fins
#
# apps/user: редирект на SSO. Без VITE_SSO_URL origin SSO строится из hostname
# текущей страницы + порт 5173 (чтобы localhost и 127.0.0.1 не путались для cookie).
# Если SSO на другом порту: VITE_SSO_DEV_PORT=5174
# VITE_SSO_URL=http://localhost:5173
