# Скопируй в `.env` в этом каталоге (`services/bff`).

# Задержка каждого ответа под /api (мс), для проверки лоадеров на фронте. 0 — отключить.
# WAIT_IN_MILLIS=300

# Секрет (зарезервировано под подпись токенов / прокси на шлюз).
SESSION_SECRET=change-me

# httpOnly cookie сессии (как в OpenAPI `BffSessionCookie`).
SESSION_COOKIE_NAME=fins_session
SESSION_MAX_AGE=604800

# Прод: true + HTTPS
COOKIE_SECURE=false
# lax | strict | none (none только с COOKIE_SECURE=true)
COOKIE_SAMESITE=lax

# Origins SPA с credentials (через запятую, без пробелов или с trim в коде).
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# Ключ для GET /api/user-service/internal/users/{id} (заголовок X-API-KEY).
# Если пусто — маршрут отвечает 503.
# BFF_SERVICE_API_KEY=dev-internal-key

# URL шлюза (когда BFF будет проксировать на бек).
# UPSTREAM_API_BASE_URL=https://api.example.com
