# ---------------------------------------------------------------------------
# Копия: скопируйте в `.env` в этой же папке (`services/bff/.env`).
# Pydantic читает переменные окружения; имена в UPPER_SNAKE_CASE по полям Settings.
# ---------------------------------------------------------------------------

# --- Сессия (cookie после логина через SSO) ---
# Секрет подписи сессии; в проде обязательно сменить.
SESSION_SECRET=change-me

# Имя cookie, которое выставляет BFF (должно совпадать с тем, что читает браузер).
SESSION_COOKIE_NAME=fins_session

# Срок жизни cookie в секундах (по умолчанию 7 дней).
SESSION_MAX_AGE_SECONDS=604800

# Cookie только по HTTPS (в локалке обычно false).
COOKIE_SECURE=false

# SameSite: lax | strict | none (none нужен для кросс-сайта с Secure).
COOKIE_SAMESITE=lax

# --- CORS: разрешённые origin фронтов (через запятую, без пробелов или с пробелами — trim).
# Должны совпадать с URL, с которых открыта админка/клиент/SSO.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174,http://127.0.0.1:5175,http://localhost:5175

# Опционально: API-ключ для внутренних вызовов BFF (если появится проверка в коде).
# BFF_SERVICE_API_KEY=

# ---------------------------------------------------------------------------
# Основной бекенд (API Gateway). Если не задан — BFF работает в режиме мок-банка (in-memory).
# ---------------------------------------------------------------------------
# Базовый URL шлюза без завершающего слэша (все пути из openApi.backend-gateway.yaml).
UPSTREAM_BASE_URL=

# Проверять TLS-сертификат upstream (false только для dev с self-signed).
UPSTREAM_VERIFY_SSL=true

# Таймаут HTTP к upstream (секунды).
UPSTREAM_TIMEOUT_SECONDS=30

# Логировать запросы к upstream (см. логи).
UPSTREAM_REQUEST_LOG=true

# Прокидывать X-USER-ID / X-USER-ROLES на путях, попадающих под маркеры (см. ниже).
UPSTREAM_GATEWAY_FORWARD_IDENTITY=true

UPSTREAM_GATEWAY_USER_ID_HEADER=X-USER-ID
UPSTREAM_GATEWAY_USER_ROLES_HEADER=X-USER-ROLES

# Подстроки путей upstream, куда добавлять identity-заголовки (через запятую). "*" — всегда.
# Подстроки URL-пути к шлюзу, для которых добавлять X-USER-ID / X-USER-ROLES, или * = все.
# Для core-api (счета, транзакции) без этого шлюз может отвечать 401.
UPSTREAM_GATEWAY_IDENTITY_PATH_MARKERS=*

# Мок казначейства банка (админские балансы); при реальном upstream обычно оставляют как в проде.
USE_MOCK_BANK_TREASURY=true

# ---------------------------------------------------------------------------
# Задержка перед обработкой каждого запроса под /api (имитация сети), миллисекунды.
# ---------------------------------------------------------------------------
WAIT_IN_MILLIS=300

# ---------------------------------------------------------------------------
# Уведомления (notification-service): SSE, unread/all/read, FCM token register/unregister.
# Задать NOTIFICATION_SERVICE_BASE_URL, если поднят сервис.
# ---------------------------------------------------------------------------
# База как в openapi notification API, без завершающего /, например:
# http://127.0.0.1:8007/api/notification-service
NOTIFICATION_SERVICE_BASE_URL=

# Тестовый SSE в самом BFF без микросервиса (вкл., пока нет NOTIFICATION_SERVICE_BASE_URL + upstream).
NOTIFICATION_SSE_MOCK_ENABLED=true

# Интервал между событиями мок-SSE (секунды).
NOTIFICATION_SSE_MOCK_INTERVAL_SECONDS=60

# Тестовый SSE без notification-service (по умолчанию включён, пока не задан NOTIFICATION_SERVICE_BASE_URL)
# NOTIFICATION_SSE_MOCK_ENABLED=false
# NOTIFICATION_SSE_MOCK_INTERVAL_SECONDS=60

# Circuit breaker (исходящие HTTP BFF → шлюз / notification-service)
# UPSTREAM_CIRCUIT_BREAKER_ENABLED=true
# UPSTREAM_CIRCUIT_FAILURE_THRESHOLD=5
# UPSTREAM_CIRCUIT_OPEN_SECONDS=30
# NOTIFICATION_CIRCUIT_BREAKER_ENABLED=true
# NOTIFICATION_CIRCUIT_FAILURE_THRESHOLD=5
# NOTIFICATION_CIRCUIT_OPEN_SECONDS=30
# ---------------------------------------------------------------------------
# Случайные 500 «Oh, it's heads» для стресс-теста фронта. Работает только БЕЗ UPSTREAM (мок-режим).
# ---------------------------------------------------------------------------
SIMULATE_RANDOM_ERRORS=false
