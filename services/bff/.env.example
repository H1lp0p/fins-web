# Пример для BFF (services/bff). Скопируй в .env и подставь значения.
# Загрузку в коде (python-dotenv / pydantic-settings) можно добавить позже.

# Базовый URL основного бекенда Fins (без завершающего /).
# UPSTREAM_API_BASE_URL=https://api.example.com

# Пример: секрет для подписи сессий (не коммить реальные значения).
# SESSION_SECRET=change-me
